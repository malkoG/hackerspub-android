"""
An individual report filed against an actor or one of their posts. Multiple reports on the same target are grouped into a single case for moderators.  A `Flag` is only resolvable by its reporter (their own report history) and by moderators; the reported user never sees `Flag` values, only the sanitized sanction surface.  Reporter-identifying fields (`reporter`) are additionally restricted to moderators.
"""
type Flag implements Node {
  """
  The case this report is grouped into.  Moderator-only: the case aggregates other reporters' reports.
  """
  case: FlagCase!

  """
  The hash of the most recent Git commit that touched the CODE_OF_CONDUCT files when the report was filed, so the report can be interpreted against the code of conduct text it was filed under.  Moderator-only.  `null` when the version could not be determined.
  """
  cocVersion: String

  """
  When the report was filed.
  """
  created: DateTime!

  """
  Whether this report arrived from another instance via an ActivityPub `Flag` activity (as opposed to being filed in-app by a local user).  External reports provide less context and come from unknown moderation cultures, so moderators should apply additional scrutiny.  Moderator-only.
  """
  external: Boolean!

  """
  Whether the reporter opted in to forwarding this report to the target's remote instance after moderator action.
  """
  forwardToRemote: Boolean!

  id: ID!

  """
  The LLM's code of conduct matching result (`matches` with provision ids, confidences, and rationales; `summary`; `model`; `analyzed`; `error` when the analysis failed).  A reference tool for moderators, never an automated decision: always verify independently.  Moderator-only.  `null` while the analysis is still pending.
  """
  llmAnalysis: JSON

  """
  The reporter's written reason.  Visible to the reporter and moderators only; never shown to the reported user, and never forwarded to remote instances (a moderator-written summary is sent instead), since the wording itself could identify the reporter.
  """
  reason: String!

  """
  The reporting actor: a local user's actor for in-app reports, or the sending remote actor (typically the remote instance actor) for reports received via ActivityPub.  Moderator-only: reporter identity is strictly confidential.
  """
  reporter: Actor!

  """
  The content snapshot captured when this report was filed, preserving the evidence even if the original is edited or deleted.  Moderator-only.
  """
  snapshot: ContentSnapshot

  """
  The report's processing status.
  """
  status: FlagStatus!

  """
  The reported actor (local or remote).
  """
  targetActor: Actor!

  """
  The reported post, for content reports; `null` for user (profile) reports, and also when the post row was deleted after the report (the snapshot preserves the evidence; `targetPostIri` remains as a stable reference).
  """
  targetPost: Post

  """
  The reported post's ActivityPub IRI; survives post deletion. `null` for user (profile) reports.
  """
  targetPostIri: URL

  """
  When the report was last updated.
  """
  updated: DateTime!

  """
  The report's row UUID.
  """
  uuid: UUID!
}

"""
An immutable audit record of a moderator decision on a case.  If a decision changes (e.g. through an appeal), a new action is recorded rather than editing this one.  Moderator-only: the reported user sees the sanitized sanction surface instead, which never names the acting moderator; a reported moderator likewise cannot access actions on their own case through this type.
"""
type FlagAction implements Node {
  """
  The decision that was made.
  """
  actionType: FlagActionType!

  """
  The case this action resolves.
  """
  case: FlagCase!

  """
  When the action was taken.
  """
  created: DateTime!

  id: ID!

  """
  The message shown to the reported user, sent under the moderation team's collective identity.
  """
  messageToUser: String

  """
  The moderator who made this decision.  Internal audit trail only: never revealed to the reported user (notifications go out under the moderation team's collective identity), so moderators cannot become individual harassment targets.
  """
  moderator: Account!

  """
  The moderator's internal judgment rationale.  May contain details not appropriate to share with the reported user; those go to `messageToUser`.
  """
  rationale: String!

  """
  The suspension window's end; only set for `SUSPEND` actions.
  """
  suspensionEnds: DateTime

  """
  The suspension window's start; only set for `SUSPEND` actions.
  """
  suspensionStarts: DateTime

  """
  The action's row UUID.
  """
  uuid: UUID!

  """
  The code of conduct provision ids the moderator confirmed as violated (empty for dismissals).  These are the human-confirmed counterpart of `Flag.llmAnalysis`; their divergence is surfaced in the moderation statistics to monitor LLM bias and automation bias.
  """
  violatedProvisions: [String!]!
}

"""
The kind of decision a moderator records on a case.  The spirit of the system is graduated response: warning, then content censorship, then temporary suspension, with permanent suspension as the last resort; severe violations may skip stages.
"""
enum FlagActionType {
  """
  Permanent suspension: a local account can no longer log in and its content is hidden; a remote actor is permanently federation-blocked.
  """
  BAN

  """
  Hide the reported post from timelines, search, and recommendations; its permalink shows a censorship notice and the author keeps access.  Requires a post target.
  """
  CENSOR

  """
  No code of conduct violation was found.
  """
  DISMISS

  """
  Temporary suspension: the local user cannot create posts, react, boost, vote, or follow until the window ends (a remote actor is federation-blocked instead).  Requires a suspension window.
  """
  SUSPEND

  """
  A warning message; for minor first offenses without apparent malice.
  """
  WARNING
}

"""
An appeal a sanctioned user filed against a moderation action. Resolvable by the appellant (their own appeal) and by moderators; moderator-only fields (`action`, `appellant`, `reviewer`) carry an additional scope so the appellant cannot reach the case, the other reports, or the moderators through their appeal.
"""
type FlagAppeal implements Node {
  """
  The appealed action, with its full audit context.  Moderator-only; a moderator who is themselves the appellant is excluded, like everywhere else on their own case.
  """
  action: FlagAction!

  """
  Context or evidence the appellant believes was not considered.
  """
  additionalContext: String

  """
  The account that filed the appeal.  Moderator-only; a moderator who is themselves the appellant is excluded.
  """
  appellant: Account!

  """
  When the appeal was filed.
  """
  created: DateTime!

  id: ID!

  """
  Why the appellant believes the action is unjust.
  """
  reason: String!

  """
  When the review completed; `null` while open.
  """
  resolved: DateTime

  """
  The review outcome; `null` until resolved.
  """
  result: FlagAppealResult

  """
  The reviewing moderator's rationale, shown to the appellant under the moderation team's collective identity.  `null` until resolved.
  """
  reviewRationale: String

  """
  The moderator who reviewed the appeal; `null` until resolved. Moderator-only: preferably a different moderator than the one who took the original action, and never revealed to the appellant, including an appellant who is themselves a moderator.
  """
  reviewer: Account

  """
  The appeal's processing status.
  """
  status: FlagAppealStatus!

  """
  The appeal's row UUID.
  """
  uuid: UUID!
}

"""
The outcome of an appeal review.
"""
enum FlagAppealResult {
  """
  The appeal was dismissed; the original action stands.
  """
  DISMISSED

  """
  Rare: review uncovered a more severe violation, and the action was replaced with a heavier one.
  """
  INCREASED

  """
  The action was reduced to a lighter one (e.g. suspension to warning); the replacement is recorded as a new action.
  """
  REDUCED

  """
  The action was withdrawn: its enforcement is reverted and it drops out of the violation history.
  """
  WITHDRAWN
}

"""
The processing status of an appeal.
"""
enum FlagAppealStatus {
  """
  Filed and awaiting review.
  """
  PENDING

  """
  The review is complete; see `result`.
  """
  RESOLVED

  """
  A moderator is reviewing the appeal.
  """
  REVIEWING
}

"""
A moderation case: all reports against the same target (an actor, or one of their posts) grouped into a single unit of moderator work.  Cases are created automatically by the first report and joined by subsequent ones while open.  Moderator-only; a reported moderator cannot access their own case (reporter anonymity would be broken otherwise).
"""
type FlagCase implements Node {
  """
  The immutable audit trail of decisions on this case, oldest first.  A case usually has one action; appeals that reduce or increase a sanction append replacement actions.
  """
  actions: [FlagAction!]!

  """
  The moderator the case is assigned to, for workload distribution; `null` when unassigned.
  """
  assignedModerator: Account

  """
  When the first report opened this case.
  """
  created: DateTime!

  """
  The individual reports grouped into this case, oldest first. Each report's reason is preserved individually; combining diverse reasons enables more accurate judgment.
  """
  flags(after: String, before: String, first: Int, last: Int): FlagCaseFlagsConnection!

  """
  Whether a non-dismiss action on this case would be forwarded to the target's remote instance: the target is a remote actor (no local account) and at least one report opted into forwarding. When `true`, `takeModerationAction` requires a `forwardSummary` for non-dismiss actions, so the internal `rationale` (which may carry reporter-identifying wording) is never externalized.  Computed over all of the case's reports, not just a page of them.
  """
  forwardingEnabled: Boolean!

  id: ID!

  """
  How many reports this case has accumulated.  Higher counts mean higher priority: multiple independent reporters finding the same issue suggests severity.
  """
  reportCount: Int!

  """
  When the case was resolved or dismissed; `null` while open.
  """
  resolved: DateTime

  """
  The case's processing status.
  """
  status: FlagStatus!

  """
  The reported actor (local or remote).
  """
  targetActor: Actor!

  """
  The reported post, for content reports; `null` for user (profile) reports and for posts deleted after the report (the snapshots on the member reports preserve the evidence).
  """
  targetPost: Post

  """
  The reported post's ActivityPub IRI; keeps the case attached to a stable target reference even after post deletion.  `null` for user (profile) reports.
  """
  targetPostIri: URL

  """
  The case's row UUID.
  """
  uuid: UUID!

  """
  The target actor's standing moderation history across all cases, newest first: dismissals are excluded, actions withdrawn or replaced on appeal drop out, and warnings expire after a violation-free year.  Accumulated history affects subsequent sanction levels.
  """
  violationHistory: [FlagAction!]!
}

type FlagCaseFlagsConnection {
  edges: [FlagCaseFlagsConnectionEdge!]!

  pageInfo: PageInfo!
}

type FlagCaseFlagsConnectionEdge {
  cursor: String!

  node: Flag!
}

"""
The processing status of an individual report.  Reports are grouped into cases; a report's status follows its case's status when the case is resolved.
"""
enum FlagStatus {
  """
  Dismissed; the report was judged not a violation.
  """
  DISMISSED

  """
  Received and awaiting moderator review.
  """
  PENDING

  """
  Processing complete; a moderation action was taken.
  """
  RESOLVED

  """
  A moderator is reviewing the case.
  """
  REVIEWING
}

"""
The `Float` scalar type represents signed double-precision fractional values as specified by [IEEE 754](https://en.wikipedia.org/wiki/IEEE_floating_point).
"""
scalar Float

input FollowActorInput {
  """
  Optional `Account` id to follow as. Omit to follow as the authenticated personal account; pass an organization account where the viewer is an accepted member to follow as that organization.
  """
  actingAccountId: ID

