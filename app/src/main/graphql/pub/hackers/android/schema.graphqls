  VERIFY_URL_NO_TOKEN
}

"""
Force a re-fetch of a remote actor or post from its origin server and overwrite the cached copy, for when the local copy is stale or broken (a renamed profile, an edited post, a missing avatar). Requires a moderator account. The fetched object only: it does not pull the actor's outbox or the post's reply tree.
"""
input RefreshRemoteObjectInput {
  clientMutationId: ID

  """
  The object to refresh, given as its ActivityPub IRI, an HTTP URL, or a `@user@host` handle. Resolved via the same federation lookup as `searchObject`. Must point to a remote object: refreshing a local actor or post raises `InvalidInputError`.
  """
  uri: String!
}

"""
The refreshed object. Exactly one of `actor` or `post` is non-`null`, matching whichever kind the URI resolved to.
"""
type RefreshRemoteObjectPayload {
  """
  The refreshed remote actor, or `null` when the URI resolved to a post.
  """
  actor: Actor

  clientMutationId: ID

  """
  The refreshed remote post, or `null` when the URI resolved to an actor.
  """
  post: Post
}

"""
Result of refreshing a remote object: the refreshed actor or post on success, or a typed error.
"""
union RefreshRemoteObjectResult = InvalidInputError|NotAuthenticatedError|NotAuthorizedError|RefreshRemoteObjectPayload

"""
The result of a successful invitations regeneration.
"""
type RegenerateInvitationsPayload {
  """
  Number of accounts whose `leftInvitations` was incremented.
  """
  accountsAffected: Int!

  """
  When the regeneration ran.
  """
  regenerated: DateTime!

  """
  The updated regeneration status reflecting the just-recorded run.
  """
  status: InvitationRegenerationStatus!
}

union RegenerateInvitationsResult = NotAuthenticatedError|NotAuthorizedError|RegenerateInvitationsPayload

"""
Returned by the deprecated APNS registration mutation when the token could not be stored. New clients should use the unified push target mutation instead.
"""
