"""
The sanitized surface a sanctioned (or warned) user sees about a moderation action taken on them: the confirmed violations, the action, the target content reference, and the moderation team's message.  Deliberately absent: the reporters, their reasons, the report count, the internal rationale, and the acting moderator's identity (everything is presented under the moderation team's collective identity).
"""
type Sanction {
  """
  What was decided.  `DISMISS` appears here only when the moderation team opted into the educational dismissal notification by writing a message.
  """
  actionType: FlagActionType!

  """
  The user's appeal against this action, or `null` when none was filed.
  """
  appeal: FlagAppeal

  """
  The appeal deadline: 14 days after the action.  One appeal per action.
  """
  appealableUntil: DateTime!

  """
  When the action was taken.
  """
  created: DateTime!

  """
  The moderation team's message.
  """
  messageToUser: String

  """
  The suspension window's end, for `SUSPEND` actions.
  """
  suspensionEnds: DateTime

  """
  The suspension window's start, for `SUSPEND` actions.
  """
  suspensionStarts: DateTime

  """
  The sanctioned post's ActivityPub IRI, when the action targeted a post; `null` for account-level actions.
  """
  targetPostIri: URL

  """
  The underlying action's row UUID; pass it to `appealModerationAction` as `sanctionId`.
  """
  uuid: UUID!

  """
  The code of conduct provision ids the moderation team confirmed as violated (empty for dismissals).
  """
  violatedProvisions: [String!]!
}

