"""
Discriminant used to filter a connection to a single post type. This enum does not appear on the `Post` interface itself; use __typename` or inline fragments to distinguish concrete types.
"""
enum PostType {
  """
  Long-form article with a title, year-based slug URL, and optional multi-language translations.
  """
  ARTICLE

  """
  Short microblog post (equivalent to a Mastodon Status or ActivityPub Note).
  """
  NOTE

  """
  ActivityPub `Question` poll. Questions may originate locally via `createQuestion` or remotely through federation.
  """
  QUESTION
}

"""
Controls who can see a post and whether it appears in timelines. Visibility is set at creation time and cannot be changed for posts that have already been federated to remote instances.
"""
enum PostVisibility {
  """
  Visible only to explicitly @-mentioned actors — the closest equivalent to a direct message. Not delivered to followers who were not mentioned.
  """
  DIRECT

  """
  Visible only to the actor's approved followers. Never appears in any public timeline. Federated only to follower inboxes.
  """
  FOLLOWERS

  """
  Not visible to anyone other than the author. Used internally for soft-deleted or administratively hidden posts; do not set this value when creating posts.
  """
  NONE

  """
  Visible to everyone including unauthenticated visitors. Appears in the public timeline and the actor's public post list. Federated to all known instances.
  """
  PUBLIC

  """
  Accessible via direct link but excluded from the public timeline. Use for posts that should be reachable without being broadcast widely.
  """
  UNLISTED
}

"""
Publish an article draft, converting it to a live `Article` post and deleting the draft. Sends an ActivityPub `Create` activity. Requires authentication.
"""
input PublishArticleDraftInput {
  """
  Optional `Account` id to publish as. The draft must still be owned by the authenticated personal account; this only changes the published article's author.
  """
  actingAccountId: ID

  allowLlmTranslation: Boolean

  """
  How to display the personal member when `actingAccountId` is an organization. Defaults to `ACTING_ACCOUNT_ONLY`; invalid when publishing as a personal account.
  """
  attributionMode: PostAttributionMode

  clientMutationId: ID

  id: ID!

  language: Locale!

  quotePolicy: QuotePolicy

  slug: String!
}

type PublishArticleDraftPayload {
  article: Article!

  clientMutationId: ID

  deletedDraftId: ID!
}

union PublishArticleDraftResult = ActorSuspendedError|InvalidInputError|NotAuthenticatedError|OrganizationPermissionError|PublishArticleDraftPayload

"""
Controls how much post content may be included in push notification payloads. Payloads can be displayed on a lock screen and pass through third-party push services.
"""
enum PushNotificationPreviewPolicy {
  """
  Include a short preview whenever the notification has post content, including restricted or sensitive posts.
  """
  ALL

  """
  Never include post content previews in push notification payloads.
  """
  NONE

  """
  Include a short preview only for non-sensitive `PUBLIC` or `UNLISTED` posts. Other notifications use generic copy.
  """
  PUBLIC_ONLY
}

"""
Push delivery service for a registered notification target. Use `WEB_PUSH` for browser Push API subscriptions.
"""
enum PushNotificationService {
  """
  Apple Push Notification service target used by iOS clients.
  """
  APNS

  """
  Firebase Cloud Messaging target used by Android clients.
  """
  FCM

  """
  Browser Push API subscription delivered with the Web Push protocol.
  """
  WEB_PUSH
}

type Query {
  """
  Look up a local account by its username (without the `@host` suffix). Returns `null` when no account with that username exists.
  """
  accountByUsername(username: String!): Account

  """
  All local accounts. Intended for internal tooling; prefer `adminAccounts` for paginated moderator views.
  """
  accounts: [Account!]!

  """
  Look up an actor by their fediverse handle (e.g., `@alice@mastodon.social` or `alice@hackers.pub`). For `user@host` handles not already in the local cache, triggers an outbound WebFinger + ActivityPub fetch and persists the result; this only happens for authenticated requests, since unauthenticated callers are not allowed to spawn outbound federation lookups.
  """
  actorByHandle("Whether to allow local handles (e.g. @username)." allowLocalHandle: Boolean = false, handle: String!): Actor

  """
  Look up an actor by their profile URL, resolving via ActivityPub when necessary. Only authenticated requests trigger outbound federation lookups; unauthenticated callers receive only cached results.
  """
  actorByUrl(url: URL!): Actor

  """
  Look up an actor by their internal row UUID (`Actor.uuid`). Prefer `actorByHandle` for user-facing lookups; this is mainly for internal cross-references where a UUID is already known.
  """
  actorByUuid(uuid: UUID!): Actor

  """
  Moderator-only connection of every account.  Returns null when the viewer is not a moderator; routes should guard with `viewer.moderator` and redirect non-moderators.
  """
  adminAccounts(after: String, before: String, first: Int, "Optional account-kind filter. Use `PERSONAL` for login-capable accounts and `ORGANIZATION` for organization accounts." kind: AccountKind, last: Int, orderBy: AdminAccountOrderBy, orderDirection: OrderDirection, search: String): AdminAccountConnection

  """
  Look up a locally-authored article by the author's handle, publication year, and URL slug. This is the resolver for the canonical article permalink path `/@{handle}/{year}/{slug}`.
  """
  articleByYearAndSlug("Optional `Account` ID that changes viewer-relative checks to an organization account managed by the authenticated viewer. Omit this argument to use the authenticated viewer's personal account." actingAccountId: ID, handle: String!, idOrYear: String!, slug: String!): Article

  """
  Look up an article draft by its global `id` or its `uuid`. Requires authentication; only returns drafts owned by the authenticated viewer.
  """
  articleDraft(id: ID, uuid: UUID): ArticleDraft

  availableLocales: [Locale!]!

  """
  The authenticated viewer's bookmarked posts, newest-bookmarked first. Throws `AUTHENTICATION_REQUIRED` when called without a session.
  """
  bookmarks(after: String, before: String, first: Int, last: Int, postType: PostType): QueryBookmarksConnection!

  codeOfConduct("The locale for the Code of Conduct." locale: Locale!): Document!

  """
  The current code of conduct, parsed into provisions, in the given locale (or the nearest available one; English by default). Backs the report form's guidance and the moderation action form's provision picker.
  """
  codeOfConductProvisions("The preferred locale for titles and text." locale: Locale): [CocProvision!]!

  """
  Moderator-only lookup of a single moderation case by its row UUID, for the case detail page.  Returns `null` for unknown UUIDs and for non-moderators.
  """
  flagCaseByUuid("The case's row UUID (`FlagCase.uuid`)." uuid: UUID!): FlagCase

  """
  Look up a known fediverse instance by its host name. Returns `null` if this instance has not been discovered yet.
  """
  instanceByHost(host: String!): Instance

  """
  Look up a specific invitation link by its UUID and the inviter's username. Returns `null` if the link does not exist or the `username` does not match the link's owner (prevents link enumeration).
  """
  invitationLink(id: UUID!, username: String!): InvitationLink

  """
  Moderator-only invitation-regeneration preview.  Returns null when the viewer is not a moderator; the route guards with `viewer.moderator` to redirect non-moderators.
  """
  invitationRegenerationStatus: InvitationRegenerationStatus

  """
  Returns all accounts as a flat array for building the invitation tree. Nodes are ordered oldest-to-newest by account creation time so that sibling ordering is stable across views.
  """
  invitationTree: [InvitationTreeNode!]!

  """
  Look up a remote Fediverse user by their handle, fetching their ActivityPub profile and constructing a remote follow URL for the given actor.
  """
  lookupRemoteFollower("The Relay global ID of the Hackers' Pub actor to be followed." actorId: ID!, "The Fediverse handle of the remote user who wants to follow (e.g., @user@mastodon.social)." followerHandle: String!): WebFingerResult

  markdownGuide("The locale for the Markdown guide." locale: Locale!): Document!

  """
  Moderator-only queue of appeals against moderation actions, newest first.  Returns `null` for non-moderators; routes should guard with `viewer.moderator`.  Use `status: PENDING` for the open queue.  A moderator's own appeals are excluded: an appellant cannot review their own appeal, and sees it through `Account.sanctions` instead.
  """
  moderationAppeals(after: String, before: String, first: Int, last: Int, "Only appeals with this status." status: FlagAppealStatus): QueryModerationAppealsConnection

  """
  Moderator-only queue of moderation cases, newest first.  Returns `null` for non-moderators; routes should guard with `viewer.moderator`.  Use `status: PENDING` for the open queue, `minReportCount` for the high-priority section, and `search` to match the target's handle or name.
  """
  moderationCases(after: String, before: String, first: Int, last: Int, "Only cases with at least this many reports, e.g. `5` for the high-priority section." minReportCount: Int, "Match the target actor's handle or display name (case-insensitive substring)." search: String, "Only cases with this status." status: FlagStatus): QueryModerationCasesConnection

  """
  Moderator-only aggregated moderation statistics over the given range (all time by default).  Returns `null` for non-moderators.
  """
  moderationStatistics("Start of the range (inclusive)." since: DateTime, "End of the range (inclusive)." until: DateTime): ModerationStatistics

  """
  Moderator-only list of news feed exclusion patterns, newest first.  `null` for non-moderators.
  """
  newsExcludedPatterns: [NewsExcludedPattern!]

  """
  Moderator-only list of news links currently carrying a score penalty, heaviest first, for reviewing/clearing demotions (a buried link is no longer near the top of the feed).  `null` for non-moderators.
  """
  newsPenalizedStories: [PostLink!]

  """
  Moderator-only list of curated preferred sharers, newest first.  `null` for non-moderators.
  """
  newsPreferredSharers: [NewsPreferredSharer!]

  """
  Moderator-only news scoring snapshot.  Returns `null` when the viewer is not a moderator; routes should guard with `viewer.moderator`.
  """
  newsScoreStatus: NewsScoreStatus

  """
  Links shared across the fediverse, ranked as a news feed.  Forward pagination only (`first`/`after`); `last`/`before` raise a `PAGINATION_ERROR`.  Pages are capped at 100 stories.  No authentication required.
  """
  newsStories(after: String, before: String, first: Int, last: Int, "How to rank the feed.  Defaults to `POPULAR`." order: NewsOrder = POPULAR): QueryNewsStoriesConnection!

  """
  Look up a news story (a shared link) by its row UUID, for the discussion permalink `/news/{uuid}`.  Returns `null` for a malformed id, or for a link that is not a public news story: only links with a qualifying public share (`latestActivity` is not `null`) resolve, so a link seen only in followers-only or direct posts stays private.  A link hidden from the feed by an exclusion pattern (`excludedFromNews`) is still reachable here.
  """
  newsStory("The link's row UUID (`PostLink.uuid`), as embedded in the `/news/{uuid}` permalink." id: UUID!): PostLink

  node(id: ID!): Node

  nodes(ids: [ID!]!): [Node]!

  """
  Look up an organization conversion request for the authenticated account. Only the account being converted, the designated accepting admin, and moderators can read it; other viewers receive `null`.
  """
  organizationConversionRequest("UUID of the `OrganizationConversionRequest` to display or accept." id: UUID!): OrganizationConversionRequest

  """
  Moderator-only orphan media preview.  Returns null when the viewer is not a moderator.
  """
  orphanMediaStatus: OrphanMediaStatus

  """
  Posts from accounts the authenticated viewer follows, newest first. Throws `AUTHENTICATION_REQUIRED` when called without a session. Pagination window (`first`/`last`) is capped at 250 posts. Use `languages` to filter by language (a base code like `"en"` matches `"en"` and all `"en-*"` variants), `local` to restrict to this instance only, and `withoutShares` to hide boost wrappers. Pass `actingAccountId` to read an organization account's feed when the viewer is an accepted member.
  """
  personalTimeline("Optional `Account` id whose feed should be read instead of the viewer's personal account. Only accepted organization members can read an organization's feed this way." actingAccountId: ID, after: String, before: String, first: Int, "Filter by base language code. Passing `\"en\"` returns posts with `language = \"en\"` or any `\"en-*\"` variant. Region-specific tags such as `\"en-US\"` are normalized to their base language and match all variants. At most 20 codes are accepted; passing more raises a `TOO_MANY_LANGUAGE_FILTERS` error." languages: [Locale!] = [], last: Int, local: Boolean = false, postType: PostType, withoutShares: Boolean = false): QueryPersonalTimelineConnection!

  """
  Resolve a post by its URL, fetching it from the originating instance via ActivityPub if it is not already cached. Requires authentication (unauthenticated callers always receive `null`). Returns `null` if the post is not found or not visible to the selected viewer account. Pass `actingAccountId` when validating a quote target for an organization account.
  """
  postByUrl("Optional `Account` ID that changes viewer-relative checks to an organization account managed by the authenticated viewer. Omit this argument to use the authenticated viewer's personal account." actingAccountId: ID, url: String!): Post

  privacyPolicy("The locale for the Privacy Policy." locale: Locale!): Document!

  """
  All public posts from all known instances, newest first. Accessible without authentication. Pagination window (`first`/`last`) is capped at 250 posts. Use `languages` to filter by language, `local` to restrict to this instance only, and `withoutShares` to hide boost wrappers.
  """
  publicTimeline(after: String, before: String, first: Int, "Filter by base language code. Passing `\"en\"` returns posts with `language = \"en\"` or any `\"en-*\"` variant. Region-specific tags such as `\"en-US\"` are normalized to their base language and match all variants. At most 20 codes are accepted; passing more raises a `TOO_MANY_LANGUAGE_FILTERS` error." languages: [Locale!] = [], last: Int, local: Boolean = false, postType: PostType, withoutShares: Boolean = false): QueryPublicTimelineConnection!

  """
  A small curated list of suggested accounts to follow, weighted toward accounts that write in the viewer's preferred locale. Capped at 50 results.
  """
  recommendedActors(limit: Int = 10, locale: Locale): [Actor!]!

  """
  Moderator-only list of ActivityPub relays this instance is subscribed to, newest first. Returns `null` when the viewer is not a moderator; routes should guard with `viewer.moderator`.
  """
  relaySubscriptions: [RelaySubscription!]

  """
  Renders a Markdown string to HTML. When `articleSourceId` is provided, `hp-medium:KEY` references in the markdown are resolved against that article source's attached media (e.g. for previewing edits to an existing article). Only the article's author may pass their own `articleSourceId`; otherwise the call is rejected.
  """
  renderMarkdown("Optional `Account` ID that changes viewer-relative checks to an organization account managed by the authenticated viewer. Omit this argument to use the authenticated viewer's personal account." actingAccountId: ID, "UUID of an `ArticleSource` owned by the viewer. When provided, the rendered HTML resolves `hp-medium:KEY` references against this source's media. The missing-medium placeholder is localized to the viewer's preferred locale." articleSourceId: UUID, "Markdown source text to render into sanitized `HTML`. Used by client-side previews while composing or editing posts." content: String!): HTML!

  """
  Moderator-only list of actors currently under an active sanction (temporary suspension, permanent suspension, or federation block), most recently sanctioned first.  Sanction activeness is evaluated lazily by time comparison, so expired suspensions disappear from this list on their own.  Returns `null` for non-moderators.
  """
  sanctionedActors: [Actor!]

  """
  Prefix search for @mention autocomplete. Matches against both username and host. Requires authentication to prevent unauthenticated callers from triggering outbound federation lookups. Capped at 50 results.
  """
  searchActorsByHandle(limit: Int = 25, prefix: String!): [Actor!]!

  searchGuide("The locale for the search guide." locale: Locale!): Document!

  """
  Look up a single actor or post by its fediverse handle (e.g., @alice@mastodon.social) or URL. Returns a local redirect URL, or null if nothing matches. For authenticated users, triggers federated WebFinger/ActivityPub lookups when the object is not already cached.
  """
  searchObject(query: String!): SearchObjectResult

  """
  Full-text post search. Supports keyword operators (see the `searchGuide` query for syntax). Only forward pagination is supported (`before`/`last` are rejected). Excludes boost wrappers; returns only original posts.
  """
  searchPost(after: String, before: String, first: Int, languages: [Locale!] = [], last: Int, query: String!): QuerySearchPostConnection!

  """
  Base language codes to show in the timeline language filter. When the viewer is authenticated and has language preferences set, returns the base codes of those locales (e.g. `ko-KR` → `ko`). Otherwise parses the `Accept-Language` request header and returns its base codes in preference order. Returns an empty list when no language information is available.
  """
  suggestedFilterLanguages: [Locale!]!

  """
  Verify a signup token and return the signup info if valid.
  """
  verifySignupToken("The verification code." code: String!, "The signup token to verify." token: UUID!): SignupInfo

  """
  The `Account` of the currently authenticated user, or `null` when not authenticated. Use this as the entry point for all viewer-specific data (notifications, drafts, settings).
  """
  viewer: Account

  """
  URL-safe Base64 VAPID public key for browser Push API subscriptions. Returns `null` when Web Push delivery is not configured on the server.
  """
  webPushVapidPublicKey: String
}

