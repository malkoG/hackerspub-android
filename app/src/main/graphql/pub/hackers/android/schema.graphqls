  clientMutationId: ID

  """
  Normalized APNS device token requested for removal.
  """
  deviceToken: String!

  """
  `true` when an owned APNS token was deleted. `false` when the token did not exist or belonged to another account.
  """
  unregistered: Boolean!
}

union UnregisterApnsDeviceTokenResult = InvalidInputError|NotAuthenticatedError|UnregisterApnsDeviceTokenPayload

"""
Legacy input for unregistering an FCM device token. Use `UnregisterPushNotificationTargetInput` for new clients.
"""
input UnregisterFcmDeviceTokenInput {
  clientMutationId: ID

  """
  FCM registration token. Surrounding whitespace is trimmed.
  """
  deviceToken: String!
}

"""
Legacy FCM unregister payload. New clients should read the unified `UnregisterPushNotificationTargetPayload` fields instead.
"""
type UnregisterFcmDeviceTokenPayload {
  clientMutationId: ID

  """
  Trimmed FCM registration token requested for removal.
  """
  deviceToken: String!

  """
  `true` when an owned FCM token was deleted. `false` when the token did not exist or belonged to another account.
  """
  unregistered: Boolean!
}

union UnregisterFcmDeviceTokenResult = InvalidInputError|NotAuthenticatedError|UnregisterFcmDeviceTokenPayload

"""
Remove a push notification target owned by the authenticated viewer. `APNS` and `FCM` identify targets by `token`; `WEB_PUSH` identifies targets by `endpoint`.
"""
input UnregisterPushNotificationTargetInput {
  clientMutationId: ID

  """
  Browser push service endpoint for `WEB_PUSH`. Must be omitted for `APNS` and `FCM`.
  """
  endpoint: String

  """
  Push service that owns the target.
  """
  service: PushNotificationService!

  """
  Device token for `APNS` or `FCM`. Must be omitted for `WEB_PUSH`.
  """
  token: String
}

"""
Successful response for `unregisterPushNotificationTarget`. Identifies the target requested for removal and whether it was owned by the viewer.
"""
type UnregisterPushNotificationTargetPayload {
  clientMutationId: ID

  """
  `WEB_PUSH` endpoint requested for removal.
  """
  endpoint: String

  """
  Push service for the requested target.
  """
  service: PushNotificationService!

  """
  `APNS` or `FCM` device token requested for removal.
  """
  token: String

  """
  `true` when an owned target was deleted. `false` when the target did not exist or belonged to a different account.
  """
  unregistered: Boolean!
}

"""
Result of unregistering a push notification target. Successful responses report whether a matching target was removed; invalid input and authentication failures are returned as typed errors.
"""
union UnregisterPushNotificationTargetResult = InvalidInputError|NotAuthenticatedError|UnregisterPushNotificationTargetPayload

"""
Undo a boost by deleting the share wrapper post and sending an ActivityPub `Undo Announce` activity. Pass the original post's `id` (not the wrapper's). Requires authentication.
