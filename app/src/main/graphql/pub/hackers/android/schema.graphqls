union UnpinPostResult = InvalidInputError|NotAuthenticatedError|OrganizationPermissionError|UnpinPostPayload

"""
Legacy input for unregistering an APNS device token. Use `UnregisterPushNotificationTargetInput` for new clients.
"""
input UnregisterApnsDeviceTokenInput {
  clientMutationId: ID

  """
  APNS device token. Hex tokens are normalized before removal.
  """
  deviceToken: String!
}

"""
Legacy APNS unregister payload. New clients should read the unified `UnregisterPushNotificationTargetPayload` fields instead.
"""
