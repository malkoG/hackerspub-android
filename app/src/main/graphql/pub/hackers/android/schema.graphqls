  """
  Maximum number of APNS device tokens this account may register.
  """
  limit: Int!

  """
  Human-readable explanation of the APNS registration failure.
  """
  message: String!
}

"""
Legacy input for registering an APNS device token. Use `RegisterPushNotificationTargetInput` for new clients.
"""
input RegisterApnsDeviceTokenInput {
  clientMutationId: ID

  """
  APNS device token. Hex tokens are normalized before storage.
  """
  deviceToken: String!
}

"""
Legacy APNS registration payload. New clients should read the unified `RegisterPushNotificationTargetPayload` fields instead.
"""
type RegisterApnsDeviceTokenPayload {
  clientMutationId: ID

  """
  When this APNS token was first registered.
  """
  created: DateTime!

  """
  Normalized APNS device token that was registered.
  """
  deviceToken: String!

  """
  When this APNS token was last refreshed.
  """
  updated: DateTime!
}

union RegisterApnsDeviceTokenResult = InvalidInputError|NotAuthenticatedError|RegisterApnsDeviceTokenFailedError|RegisterApnsDeviceTokenPayload

"""
Returned by the deprecated FCM registration mutation when the token could not be stored. New clients should use the unified push target mutation instead.
"""
type RegisterFcmDeviceTokenFailedError {
  """
  Maximum number of FCM device tokens this account may register.
  """
  limit: Int!

  """
  Human-readable explanation of the FCM registration failure.
  """
  message: String!
}

"""
Legacy input for registering an FCM device token. Use `RegisterPushNotificationTargetInput` for new clients.
"""
input RegisterFcmDeviceTokenInput {
  clientMutationId: ID

  """
  FCM registration token. Surrounding whitespace is trimmed.
  """
  deviceToken: String!
}

"""
Legacy FCM registration payload. New clients should read the unified `RegisterPushNotificationTargetPayload` fields instead.
"""
type RegisterFcmDeviceTokenPayload {
  clientMutationId: ID

  """
  When this FCM token was first registered.
  """
  created: DateTime!

  """
  Trimmed FCM registration token that was registered.
  """
