  clientMutationId: ID

  """
  The pending conversion request. Give `request.uuid` to the named admin so they can accept it.
  """
  request: OrganizationConversionRequest!
}

union RequestOrganizationConversionResult = InvalidInputError|NotAuthenticatedError|NotAuthorizedError|OrganizationConversionError|RequestOrganizationConversionPayload

